{
  "id": "ftl-trainer",
  "name": "FTL: Faster Than Light",
  "version": 1,
  "mode": "trainer",
  "requires": [
    "memory_pointer_chain"
  ],
  "process_name": "FTL.amd64",
  "game_version": "1.6.29",
  "steam_buildid": "4710954",
  "poll_interval_ms": 250,
  "description": "Trainer for FTL: Faster Than Light (Linux native, v1.6.29). Pointer chains follow: [0x63A7F8] = ShipStatus/CommandGui*, +0x10 = ShipManager*. Resource fields use freeze-on-enable to maintain values every poll tick. Power uses code patches since the PowerManager has clean single-path functions.",
  "fields": [
    {
      "id": "infinite_fuel",
      "name": "Infinite Fuel",
      "type": "patch",
      "widget": "switch",
      "category": "Resources",
      "description": "Fuel stays at 99",
      "freeze_on_enable": true,
      "address": {
        "method": "memory_pointer_chain",
        "module": "FTL.amd64",
        "offset": "0x0"
      },
      "on_enable": {
        "description": "Set fuel to 99 via ShipManager->fuel (+0x610)",
        "chain": [
          "0x63A7F8",
          "0x10",
          "0x610"
        ],
        "writes": [
          {
            "offset": "0x0",
            "type": "int32",
            "value": 99
          }
        ]
      }
    },
    {
      "id": "infinite_missiles",
      "name": "Infinite Missiles",
      "type": "patch",
      "widget": "switch",
      "category": "Resources",
      "description": "Missiles stay at 99",
      "freeze_on_enable": true,
      "address": {
        "method": "memory_pointer_chain",
        "module": "FTL.amd64",
        "offset": "0x0"
      },
      "on_enable": {
        "description": "Set missiles to 99 via ShipManager fallback (+0x8F4)",
        "chain": [
          "0x63A7F8",
          "0x10",
          "0x8F4"
        ],
        "writes": [
          {
            "offset": "0x0",
            "type": "int32",
            "value": 99
          }
        ]
      },
      "on_enable_alt": {
        "description": "Set missiles to 99 via WeaponControl (+0x88) -> +0x288",
        "chain": [
          "0x63A7F8",
          "0x10",
          "0x88",
          "0x288"
        ],
        "writes": [
          {
            "offset": "0x0",
            "type": "int32",
            "value": 99
          }
        ]
      }
    },
    {
      "id": "infinite_drones",
      "name": "Infinite Drone Parts",
      "type": "patch",
      "widget": "switch",
      "category": "Resources",
      "description": "Drone parts stay at 99",
      "freeze_on_enable": true,
      "address": {
        "method": "memory_pointer_chain",
        "module": "FTL.amd64",
        "offset": "0x0"
      },
      "on_enable": {
        "description": "Set drone parts to 99 via ShipManager fallback (+0x8F0)",
        "chain": [
          "0x63A7F8",
          "0x10",
          "0x8F0"
        ],
        "writes": [
          {
            "offset": "0x0",
            "type": "int32",
            "value": 99
          }
        ]
      },
      "on_enable_alt": {
        "description": "Set drone parts to 99 via DroneControl (+0x90) -> +0x260",
        "chain": [
          "0x63A7F8",
          "0x10",
          "0x90",
          "0x260"
        ],
        "writes": [
          {
            "offset": "0x0",
            "type": "int32",
            "value": 99
          }
        ]
      }
    },
    {
      "id": "infinite_scrap",
      "name": "Infinite Scrap",
      "type": "patch",
      "widget": "switch",
      "category": "Resources",
      "description": "Scrap stays at 99999",
      "freeze_on_enable": true,
      "address": {
        "method": "memory_pointer_chain",
        "module": "FTL.amd64",
        "offset": "0x0"
      },
      "on_enable": {
        "description": "Set scrap to 99999 via ShipManager->scrap (+0x670)",
        "chain": [
          "0x63A7F8",
          "0x10",
          "0x670"
        ],
        "writes": [
          {
            "offset": "0x0",
            "type": "int32",
            "value": 99999
          }
        ]
      }
    },
    {
      "id": "infinite_power",
      "name": "Infinite Power",
      "type": "patch",
      "widget": "switch",
      "category": "Ship",
      "description": "Reactor always full. Freely allocate power to all systems.",
      "address": {
        "method": "memory_pointer_chain",
        "module": "FTL.amd64",
        "offset": "0x0"
      },
      "on_enable": {
        "description": "Set reactor to full (used=0, total=30) via PowerManager::powerManagers[0]",
        "chain": [
          "0x647C70",
          "0x0"
        ],
        "writes": [
          {
            "offset": "0x0",
            "type": "int32",
            "value": 0
          },
          {
            "offset": "0x4",
            "type": "int32",
            "value": 30
          }
        ]
      },
      "patches": [
        {
          "description": "NOP 'add [rdi], 1' in IncreasePower \u2014 stops used_power from incrementing when powering a system",
          "offset": "0x244CDB",
          "original": "830701",
          "patch": "909090"
        },
        {
          "description": "NOP 'jl' availability check in IncreasePower \u2014 allows allocation even when reactor shows no free bars",
          "offset": "0x244CBC",
          "original": "7C72",
          "patch": "9090"
        },
        {
          "description": "NOP 'sub [rdi], 1' in DecreasePower \u2014 stops used_power from decrementing when depowering a system",
          "offset": "0x244C3A",
          "original": "832F01",
          "patch": "909090"
        }
      ]
    },
    {
      "id": "invincible_hull",
      "name": "Invincible Hull",
      "type": "patch",
      "widget": "switch",
      "category": "Ship",
      "description": "Ship takes no hull damage. Hull set to max on enable.",
      "address": {
        "method": "memory_pointer_chain",
        "module": "FTL.amd64",
        "offset": "0x0"
      },
      "on_enable": {
        "description": "Set hull to max (30) via ShipManager -> Ship.hull (+0x188)",
        "chain": [
          "0x63A7F8",
          "0x10",
          "0x188"
        ],
        "writes": [
          {
            "offset": "0x0",
            "type": "int32",
            "value": 30
          }
        ]
      },
      "patches": [
        {
          "description": "Replace Ship::DamageHull entry with 'mov eax,[rdi+0x70]; ret' \u2014 returns current hull without modifying, blocking all hull damage from any caller",
          "offset": "0xA2300",
          "original": "85F67E24",
          "patch": "8B4770C3"
        }
      ]
    },
    {
      "id": "infinite_cloak",
      "name": "Infinite Cloaking",
      "type": "patch",
      "widget": "switch",
      "category": "Ship",
      "description": "Cloak never expires once activated",
      "freeze_on_enable": true,
      "address": {
        "method": "memory_pointer_chain",
        "module": "FTL.amd64",
        "offset": "0x0"
      },
      "on_enable": {
        "description": "Reset cloak timer to 0 via ShipManager -> CloakingSystem (+0x50) -> TimerHelper.current (+0x250)",
        "chain": [
          "0x63A7F8",
          "0x10",
          "0x50",
          "0x250"
        ],
        "writes": [
          {
            "offset": "0x0",
            "type": "float32",
            "value": 0.0
          }
        ]
      }
    }
  ]
}
