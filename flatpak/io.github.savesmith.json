{
  "app-id": "io.github.savesmith",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "savesmith",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=wayland",
    "--socket=x11",
    "--device=dri",
    "--filesystem=home",
    "--filesystem=xdg-data/savesmith:create",
    "--filesystem=/proc:ro",
    "--allow=devel",
    "--talk-name=org.freedesktop.Flatpak"
  ],
  "modules": [
    {
      "name": "savesmith",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "dir",
          "path": ".."
        }
      ]
    }
  ]
}
